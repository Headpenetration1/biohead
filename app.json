{
  "expo": {
    "name": "Biohead",
    "slug": "biohead",
    "version": "1.0.0",
    "description": "Pusteøvelser for ro, fokus og energi. Din daglige mindfulness-kompanjong.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "biohead",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#020508",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "no.biohead.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#020508"
      },
      "package": "no.biohead.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-av",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}