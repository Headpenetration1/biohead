{
  "expo": {
    "name": "Biohead",
    "slug": "biohead",
    "version": "1.0.0",
    "description": "Pusteøvelser for ro, fokus og energi. Din daglige mindfulness-kompanjong.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "biohead",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#FFF9ED",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "no.biohead.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Biohead kan bruke Helse for å synkronisere mindful minutes når du velger det.",
        "NSHealthUpdateUsageDescription": "Biohead lagrer mindful minutes i Apple Helse når du fullfører en pusteøkt (valgfritt)."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFF9ED"
      },
      "package": "no.biohead.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-av",
      "expo-notifications",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
